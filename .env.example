# .env.example
# This file provides an example configuration.
# Copy this to a new file named .env and fill in your actual values.

# PostgreSQL Database
# Use the service name from docker-compose.yml as the host
POSTGRES_USER=eve_user
POSTGRES_PASSWORD=strongpassword
POSTGRES_DB=eve_market_analysis
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
# Use the service name from docker-compose.yml as the host
REDIS_HOST=redis
REDIS_PORT=6379

# API Security
# Replace with a strong, secret API key
API_KEY=your_secret_api_key_here

# Logging
# Can be DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Cloudflared (Optional)
# If you are using a Cloudflare Tunnel, provide your token here.
# CLOUDFLARED_TOKEN=your_token_here