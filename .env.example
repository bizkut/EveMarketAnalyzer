# PostgreSQL
POSTGRES_SERVER=db
POSTGRES_USER=eve_user
POSTGRES_PASSWORD=eve_password
POSTGRES_DB=eve_market_analyzer

# Database URL
DATABASE_URL=postgresql://eve_user:eve_password@db/eve_market_analyzer

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API Key
API_KEY=your_secret_api_key

# Logging
LOG_LEVEL=INFO

# ESI - EVE Swagger Interface
ESI_BASE_URL=https://esi.evetech.net/latest
USER_AGENT=EveMarketAnalyzer/1.0.0 your.email@example.com