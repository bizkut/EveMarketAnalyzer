# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=eve_market
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Cloudflared
CLOUDFLARED_TOKEN=your_cloudflared_token_here

# API Security
API_KEY=your_secret_api_key

# Logging
LOG_LEVEL=INFO